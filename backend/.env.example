# Database
DATABASE_URL=postgresql://user:password@host:5432/crm_core

# Redis
REDIS_URL=redis://user:password@host:6379
CELERY_BROKER_URL=redis://user:password@host:6379
CELERY_RESULT_BACKEND=redis://user:password@host:6379

# JWT
SECRET_KEY=generate-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development

# Bootstrap Admin (created on first run if no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=your-admin-password
BOOTSTRAP_ADMIN_FULL_NAME=CRM Admin
BOOTSTRAP_ADMIN_ROLE=admin

# SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@crm-core.local

# WhatsApp Cloud API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000